<section class="category-tiles">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Shop by Category</p>
      <h2>Something for every sniff.</h2>
    </div>

    <div class="category-tiles__grid">
      <a href="/collections/fragrances" class="category-tile category-tile--purple">
        <h3>Fragrances</h3>
        <span>Harm-free scented colognes</span>
      </a>
      <a href="/collections/shampoos" class="category-tile category-tile--pink">
        <h3>Shampoos</h3>
        <span>Spa-grade, gentle on skin</span>
      </a>
      <a href="/collections/supplements" class="category-tile category-tile--olive">
        <h3>Supplements</h3>
        <span>Lab-tested chewable support</span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category tiles",
  "presets": [{ "name": "Category tiles" }]
}
{% endschema %}
