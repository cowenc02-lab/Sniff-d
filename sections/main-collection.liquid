<div class="collection-header">
  <p class="eyebrow">Collection</p>
  <h1>{{ collection.title }}</h1>
  {% if collection.description != blank %}<p>{{ collection.description }}</p>{% endif %}
</div>

<div class="collection-grid-wrap container">
  {% paginate collection.products by 24 %}
    <div class="product-grid">
      {% for product in collection.products %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <div style="display:flex; gap:10px; justify-content:center; margin-top:50px;">
        {% if paginate.previous %}<a href="{{ paginate.previous.url }}" class="btn btn--outline">Prev</a>{% endif %}
        {% for part in paginate.parts %}
          {% if part.is_link %}
            <a href="{{ part.url }}" class="btn btn--outline">{{ part.title }}</a>
          {% else %}
            <span class="btn btn--olive">{{ part.title }}</span>
          {% endif %}
        {% endfor %}
        {% if paginate.next %}<a href="{{ paginate.next.url }}" class="btn btn--outline">Next</a>{% endif %}
      </div>
    {% endif %}
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Main collection",
  "settings": []
}
{% endschema %}
