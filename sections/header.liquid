<header class="site-header">
  <div class="site-header__inner container">
    <a href="{{ routes.root_url }}" class="site-header__logo"><img src="{{ 'sniffd-wordmark.png' | asset_url }}" alt="{{ section.settings.logo_text | default: "Sniff'd" }}" class="site-header__logo-img" width="140" height="37"></a>

    <nav>
      <ul class="site-header__nav">
        {% for link in section.settings.menu.links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </nav>

    <div class="site-header__icons">
      <button class="mobile-nav-toggle" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <a href="{{ routes.search_url }}" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M3 6h2l2.4 12.4a2 2 0 002 1.6h9.2a2 2 0 002-1.6L21 8H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="21" r="1.5" fill="currentColor"/><circle cx="18" cy="21" r="1.5" fill="currentColor"/></svg>
        <span class="header-cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "Sniff'd" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
