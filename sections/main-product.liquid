<section class="product-detail container">
  <div class="product-detail__gallery">
    {% if product.featured_image %}
      <img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" width="900" height="900">
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}
  </div>

  <div class="product-detail__info">
    {% if product.type %}<p class="eyebrow">{{ product.type }}</p>{% endif %}
    <h1 class="product-detail__title">{{ product.title }}</h1>
    <div class="product-detail__price">
      {% if product.compare_at_price > product.price %}
        <s>{{ product.compare_at_price | money }}</s> {{ product.price | money }}
      {% else %}
        {{ product.price | money }}
      {% endif %}
    </div>

    <div class="product-detail__description">
      {{ product.description }}
    </div>

    {% form 'product', product %}
      {% unless product.has_only_default_variant %}
        {% for option in product.options_with_values %}
          <div class="variant-picker" data-variant-picker data-target="#variant-id-{{ product.id }}">
            <span class="variant-picker__label">{{ option.name }}</span>
            <div class="variant-picker__options">
              {% for value in option.values %}
                {% assign matched_variant = product.variants | where: 'title', value | first %}
                <span
                  class="variant-swatch{% if forloop.first %} is-selected{% endif %}"
                  data-variant-id="{{ matched_variant.id | default: product.selected_or_first_available_variant.id }}">
                  {{ value }}
                </span>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      {% endunless %}

      <input type="hidden" name="id" id="variant-id-{{ product.id }}" value="{{ product.selected_or_first_available_variant.id }}">

      <div class="qty-add-row">
        <input type="number" name="quantity" class="qty-input" value="1" min="1">
        <button type="submit" class="btn btn--olive" {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}Add to Cart — Sniff Approved 🐾{% else %}Sold Out{% endif %}
        </button>
      </div>
    {% endform %}

    <div class="product-detail__badges">
      <span class="badge">Harm-Free</span>
      <span class="badge">Vet Reviewed</span>
      <span class="badge">Made for Dogs & Cats</span>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.product-detail .qty-add-row').forEach(function(row){
    row.closest('form').setAttribute('data-add-to-cart-form', '');
  });
</script>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
