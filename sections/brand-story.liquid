<section class="brand-story">
  <div class="container">
    <p class="eyebrow" style="color:var(--color-cream); opacity:0.7;">{{ section.settings.eyebrow | default: "Why Sniff'd" }}</p>
    <h2>{{ section.settings.heading | default: "Good for them. Great for you." }}</h2>
    <p>{{ section.settings.text | default: "We make premium, harm-free products that actually work — lab-tested supplements, gentle spa shampoos, and fragrances that won't irritate sensitive noses. Because 'good enough' isn't good enough for your good boy." }}</p>
    <a href="{{ section.settings.link | default: '/pages/about' }}" class="btn btn--pink">Our Story</a>
  </div>
</section>

{% schema %}
{
  "name": "Brand story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Sniff'd" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Good for them. Great for you." },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "url", "id": "link", "label": "Button link" }
  ],
  "presets": [{ "name": "Brand story" }]
}
{% endschema %}
