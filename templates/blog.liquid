<div class="container" style="padding:60px 24px 100px;">
  <div class="collection-header" style="padding:0 0 20px;">
    <p class="eyebrow">Blog</p>
    <h1>{{ blog.title }}</h1>
  </div>
  <div class="product-grid">
    {% for article in blog.articles %}
      <a href="{{ article.url }}" class="product-card">
        <div class="product-card__image">
          {% if article.image %}<img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}">{% endif %}
        </div>
        <div class="product-card__body">
          <h3 class="product-card__title">{{ article.title }}</h3>
          <p style="color:var(--color-gray); font-size:14px;">{{ article.excerpt_or_content | strip_html | truncate: 90 }}</p>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
