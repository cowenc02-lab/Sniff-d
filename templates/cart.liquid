<div class="container" style="padding:60px 24px 100px;">
  <h1>Your Cart</h1>
  {% if cart.item_count == 0 %}
    <p>Your cart's empty — time to go sniff around the shop.</p>
    <a href="/collections/all" class="btn btn--olive">Shop All Products</a>
  {% else %}
    {% form 'cart' %}
      <table style="width:100%; border-collapse:collapse; margin-top:20px;">
        <thead>
          <tr style="text-align:left; border-bottom:2px solid var(--color-cream-dark);">
            <th style="padding:12px 0;">Product</th>
            <th>Quantity</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            <tr style="border-bottom:1px solid var(--color-cream-dark);">
              <td style="padding:14px 0;">
                <a href="{{ item.url }}">{{ item.product.title }}</a>
                {% unless item.variant.title == 'Default Title' %}<div style="color:var(--color-gray); font-size:13px;">{{ item.variant.title }}</div>{% endunless %}
              </td>
              <td><input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="qty-input"></td>
              <td>{{ item.final_line_price | money }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
      <div style="text-align:right; margin-top:24px;">
        <p style="font-weight:700; font-size:18px;">Subtotal: {{ cart.total_price | money }}</p>
        <button type="submit" name="update" class="btn btn--outline">Update Cart</button>
        <button type="submit" name="checkout" class="btn btn--olive">Checkout</button>
      </div>
    {% endform %}
  {% endif %}
</div>
